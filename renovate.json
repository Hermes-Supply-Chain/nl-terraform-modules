{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prHourlyLimit": 5,
  "enabledManagers": [
    "github-actions",
    "terraform",
    "pip_requirements"
  ],
  "fetchChangeLogs": "pr",
  "suppressNotifications": [
    "prIgnoreNotification"
  ],
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "description": "Do not show non-major updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "enabled": false
    },
    {
      "description": "Create pull requests for major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "automergeType": "pr"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true
}
